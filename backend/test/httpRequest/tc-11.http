@baseUrl = http://localhost:3050/api/v1

### Preparacion - Plantilla EMAIL
# @name emailTemplate
POST {{baseUrl}}/templates
X-API-Key: {{$dotenv SERVICE_API_KEY}}
Content-Type: application/json

{ "nombre": "tc11-email-{{$timestamp}}", "canal": "EMAIL", "contenido": "Hola \u007b\u007bnombre\u007d\u007d, pedido \u007b\u007bpedido\u007d\u007d", "variables": ["nombre", "pedido"] }

### TC-11 - Encolar notificacion EMAIL valida
# @name emailNotification
POST {{baseUrl}}/notifications
X-API-Key: {{$dotenv SERVICE_API_KEY}}
Idempotency-Key: tc11-email-{{$timestamp}}
Content-Type: application/json

{
  "canal": "EMAIL",
  "destinatario": "cliente@example.com",
  "plantillaId": {{emailTemplate.response.body.$.id}},
  "variables": { "nombre": "Ana", "pedido": 4521 }
}
