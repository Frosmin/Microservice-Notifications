@baseUrl = http://localhost:3050/api/v1

### Preparacion - Plantilla SMS
# @name smsTemplate
POST {{baseUrl}}/templates
X-API-Key: {{$dotenv SERVICE_API_KEY}}
Content-Type: application/json

{ "nombre": "tc12-sms-{{$timestamp}}", "canal": "SMS", "contenido": "Tu codigo es \u007b\u007bcodigo\u007d\u007d", "variables": ["codigo"] }

### TC-12 - Encolar notificacion SMS valida
# @name smsNotification
POST {{baseUrl}}/notifications
X-API-Key: {{$dotenv SERVICE_API_KEY}}
Idempotency-Key: tc12-sms-{{$timestamp}}
Content-Type: application/json

{
  "canal": "SMS",
  "destinatario": "+59170000000",
  "plantillaId": {{smsTemplate.response.body.$.id}},
  "variables": { "codigo": "123456" }
}
